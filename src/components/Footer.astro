---
const quickLinks = [
  { label: 'About Us',          href: '#about' },
  { label: 'Wholesale Program', href: '#wholesale' },
  { label: 'Shipping Policy',   href: '#' },
  { label: 'Return Policy',     href: '#' },
  { label: 'FAQs',              href: '#' },
  { label: 'Blog',              href: '#' },
];

const productLinks = [
  { label: 'Faucets',         href: '#' },
  { label: 'Bathroom Sinks',  href: '#' },
  { label: 'Shower Systems',  href: '#' },
  { label: 'Bathtubs',        href: '#' },
  { label: 'Toilets & Bidets',href: '#' },
  { label: 'Accessories',     href: '#' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__main">
    <div class="container footer__grid">

      <!-- Brand column -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          xoxo<strong>china</strong>
        </a>
        <p class="footer__tagline">
          Premium bathroom fixtures for retail and wholesale. Elevating spaces since 2010.
        </p>
        <div class="footer__social">
          <a href="#" aria-label="Facebook">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" aria-label="YouTube">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.4 19.54C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>
          </a>
          <a href="#" aria-label="WhatsApp">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div class="footer__links">
        <h4>Quick Links</h4>
        <ul>
          {quickLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <!-- Products -->
      <div class="footer__links">
        <h4>Products</h4>
        <ul>
          {productLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer__contact">
        <h4>Contact Us</h4>
        <ul>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.62 4.4 2 2 0 0 1 3.59 2.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.92 17z"/></svg>
            <span>+1 (800) 123-4567</span>
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>info@xoxochina.com</span>
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>123 Trade District, Commerce City, CA 90001</span>
          </li>
        </ul>
        <div class="footer__hours">
          <p><strong>Business Hours</strong></p>
          <p>Mon – Fri: 9:00 AM – 6:00 PM PST</p>
          <p>Sat: 10:00 AM – 4:00 PM PST</p>
        </div>
      </div>

    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {currentYear} xoxochina. All rights reserved.</p>
      <div class="footer__legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__main {
    padding: 4.5rem 0 3rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.3fr;
    gap: 3rem;
  }

  /* Logo */
  .footer__logo {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 1.375rem;
    color: #fff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .footer__logo strong {
    color: var(--color-accent);
  }

  .footer__tagline {
    font-size: 0.875rem;
    line-height: 1.75;
    margin-bottom: 1.75rem;
  }

  .footer__social {
    display: flex;
    gap: 0.5rem;
  }

  .footer__social a {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.6);
    transition: background var(--transition), color var(--transition);
  }

  .footer__social a:hover {
    background: var(--color-accent);
    color: #fff;
  }

  /* Link columns */
  .footer__links h4,
  .footer__contact h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1.25rem;
  }

  .footer__links ul,
  .footer__contact ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__links a {
    font-size: 0.875rem;
    transition: color var(--transition);
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
  }

  .footer__contact svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .footer__hours {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.8125rem;
    line-height: 1.85;
  }

  .footer__hours strong {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    padding: 1.25rem 0;
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__bottom p {
    font-size: 0.8125rem;
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer__legal a {
    font-size: 0.8125rem;
    transition: color var(--transition);
  }

  .footer__legal a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 1100px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
