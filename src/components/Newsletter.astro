<section class="newsletter" id="contact">
  <div class="container newsletter__inner">
    <div class="newsletter__text">
      <h2 class="newsletter__title">Stay in the Loop</h2>
      <p>New arrivals, curated highlights, and product updates delivered to your inbox.</p>
    </div>
    <form class="newsletter__form" id="newsletter-form" novalidate>
      <div class="form-group">
        <input
          type="email"
          id="nl-email"
          placeholder="Enter your email address"
          aria-label="Email address"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </div>
      <p class="form-note">No spam, ever. Unsubscribe at any time.</p>
      <p class="form-success" id="nl-success" aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  .newsletter {
    background: linear-gradient(135deg, var(--color-accent-dark) 0%, var(--color-accent) 100%);
    padding: 3.5rem 0;
  }

  .newsletter__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .newsletter__text {
    flex: 1;
    min-width: 220px;
  }

  .newsletter__title {
    font-family: var(--font-serif);
    font-size: 1.875rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.375rem;
  }

  .newsletter__text p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9375rem;
  }

  .newsletter__form {
    flex: 1;
    max-width: 460px;
  }

  .form-group {
    display: flex;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .form-group input {
    flex: 1;
    padding: 0.9rem 1.25rem;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 0.9375rem;
    background: #fff;
    color: var(--color-text);
    min-width: 0;
  }

  .form-group .btn {
    border-radius: 0;
    background: var(--color-primary);
    border-color: var(--color-primary);
    padding-inline: 1.5rem;
    white-space: nowrap;
  }

  .form-group .btn:hover {
    background: rgba(13, 27, 42, 0.82);
    border-color: rgba(13, 27, 42, 0.82);
  }

  .form-note {
    margin-top: 0.625rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.62);
  }

  .form-success {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
    min-height: 1.2em;
  }

  @media (max-width: 768px) {
    .newsletter__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .newsletter__form {
      width: 100%;
      max-width: none;
    }
  }
</style>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const successMsg = document.getElementById('nl-success') as HTMLParagraphElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]') as HTMLInputElement;
    if (!input.value || !input.validity.valid) {
      input.focus();
      return;
    }
    successMsg.textContent = 'Thanks for subscribing! Check your inbox soon.';
    input.value = '';
  });
</script>
