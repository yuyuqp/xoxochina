---
import { productMedia } from '../data/productMedia';

const products = productMedia.map((product, index) => ({
  ...product,
  rating: [4.9, 4.8, 4.8, 5, 4.7, 4.6, 4.8, 4.7][index] ?? 4.8,
  reviews: [124, 97, 88, 42, 73, 61, 56, 69][index] ?? 48,
}));
---

<section class="featured" id="featured">
  <div class="container">
    <div class="featured__header">
      <div>
        <span class="section-label">Handpicked Selection</span>
        <h2 class="section-title">Bestselling Products</h2>
      </div>
      <a href="#wholesale" class="btn btn-outline">Get a Quote</a>
    </div>

    <div class="products__grid">
      {products.map((p) => (
        <article class="product-card">
          <a href="#wholesale" class="product-card__img-link" aria-label={`Request a quote for ${p.title}`}>
            {p.badge && (
              <span class={`product-card__badge badge--${p.badgeColor}`}>{p.badge}</span>
            )}
            <img src={p.imageUrl} alt={p.title} width="350" height="350" loading="lazy" referrerpolicy="no-referrer" />
            <div class="product-card__actions">
              <span class="product-card__quote">Get quote</span>
            </div>
          </a>
          <div class="product-card__body">
            <p class="product-card__cat">{p.category}</p>
            <h3 class="product-card__name">
              <a href="#wholesale">{p.title}</a>
            </h3>
            <div class="product-card__rating">
              <span class="stars" aria-label={`${p.rating} out of 5`}>
                {[1,2,3,4,5].map((i) => (
                  <svg width="12" height="12" viewBox="0 0 24 24"
                    fill={i <= Math.round(p.rating) ? 'currentColor' : 'none'}
                    stroke="currentColor" stroke-width="1.5">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </span>
              <span class="rating-text">{p.rating} ({p.reviews})</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured {
    padding: 5rem 0;
    background: var(--color-bg-soft);
  }

  .featured__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .product-card {
    background: #ffffff;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .product-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .product-card__img-link {
    display: block;
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .product-card__img-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
    background: #f8f8f8;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card__img-link img {
    transform: scale(1.07);
  }

  .product-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
  }

  .badge--gold { background: var(--color-accent); color: #fff; }
  .badge--blue { background: #3b82f6; color: #fff; }
  .badge--red  { background: #ef4444; color: #fff; }
  .badge--dark { background: var(--color-primary); color: #fff; }

  .product-card__actions {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    opacity: 0;
    transform: translateX(8px);
    transition: opacity var(--transition), transform var(--transition);
  }

  .product-card:hover .product-card__actions {
    opacity: 1;
    transform: translateX(0);
  }

  .product-card__quote {
    background: #fff;
    border: none;
    min-height: 34px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.75rem;
    box-shadow: var(--shadow-sm);
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: background var(--transition), color var(--transition);
  }

  .product-card__img-link:hover .product-card__quote {
    background: var(--color-primary);
    color: #fff;
  }

  .product-card__body {
    padding: 1.125rem;
  }

  .product-card__cat {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: 0.3rem;
  }

  .product-card__name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: 1.35;
    min-height: 2.55em;
  }

  .product-card__name a:hover {
    color: var(--color-accent-dark);
  }

  .product-card__rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .stars {
    display: flex;
    gap: 1px;
    color: var(--color-accent);
  }

  .rating-text {
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 1100px) {
    .products__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .products__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .products__grid { grid-template-columns: 1fr; }
  }
</style>
