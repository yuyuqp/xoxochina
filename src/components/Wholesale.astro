---
const perks = [
  'Tiered volume support',
  'Dedicated account manager',
  'Early access to new products',
  'Flexible payment terms',
  'Custom packaging available',
  'Priority shipping & fulfillment',
];

const wstats = [
  { num: '500+',  label: 'Active Wholesale Partners' },
  { num: '25%',   label: 'Average Wholesale Efficiency' },
  { num: '48h',   label: 'Quote Turnaround Time' },
  { num: 'MOQ 10', label: 'Minimum Order Quantity' },
];
---

<section class="wholesale" id="wholesale">
  <div class="container wholesale__inner">
    <div class="wholesale__text">
      <span class="section-label">For Businesses</span>
      <h2 class="section-title light">Partner With xoxochina</h2>
      <p class="wholesale__desc">
        Whether you're a plumbing contractor, interior designer, or retail store owner, our wholesale program gives you access to a massive product catalog and dedicated support.
      </p>
      <ul class="wholesale__perks">
        {perks.map((perk) => (
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {perk}
          </li>
        ))}
      </ul>
      <div class="wholesale__ctas">
        <a href="#contact" class="btn btn-primary btn-lg">Apply for Wholesale Account</a>
        <a href="#" class="btn btn-outline-light">Download Catalog</a>
      </div>
    </div>

    <div class="wholesale__stats">
      {wstats.map((s) => (
        <div class="wstat">
          <span class="wstat__num">{s.num}</span>
          <span class="wstat__label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .wholesale {
    padding: 5.5rem 0;
    background: var(--color-bg-dark);
    background-image:
      radial-gradient(circle at 15% 50%, rgba(201, 166, 107, 0.07) 0%, transparent 50%),
      radial-gradient(circle at 85% 15%, rgba(201, 166, 107, 0.05) 0%, transparent 40%);
  }

  .wholesale__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .wholesale__text .section-label {
    color: var(--color-accent);
  }

  .wholesale__text .section-title {
    margin-top: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .wholesale__desc {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.62);
    margin-bottom: 2rem;
  }

  .wholesale__perks {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem 2rem;
    margin-bottom: 2.5rem;
  }

  .wholesale__perks li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .wholesale__perks svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .wholesale__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .wholesale__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .wstat {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: background var(--transition), border-color var(--transition);
  }

  .wstat:hover {
    background: rgba(201, 166, 107, 0.09);
    border-color: rgba(201, 166, 107, 0.28);
  }

  .wstat__num {
    display: block;
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
    line-height: 1;
  }

  .wstat__label {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .wholesale__inner {
      gap: 3rem;
    }
  }

  @media (max-width: 900px) {
    .wholesale__inner {
      grid-template-columns: 1fr;
    }

    .wholesale__perks {
      grid-template-columns: 1fr;
    }
  }
</style>
