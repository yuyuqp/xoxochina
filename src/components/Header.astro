---

---

<header class="header" id="site-header">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="xoxochina home">
      <img
        src="/logo-inline-120x56.png"
        alt="xoxochina logo"
        width="120"
        height="56"
        class="logo-inline"
      />
      <span class="logo-text">xoxo<strong>china</strong></span>
    </a>

    <!-- Navigation -->
    <nav class="header__nav" id="main-nav" aria-label="Main navigation">
      <ul>
        <li><a href="#categories">Products</a></li>
        <li><a href="#featured">Collections</a></li>
        <li><a href="#wholesale">Wholesale</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <button class="icon-btn" aria-label="Search">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </button>
      <a href="#wholesale" class="btn btn-primary header__cta">Get a Quote</a>
      <button
        class="menu-btn"
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;
  }

  .header.scrolled {
    box-shadow: var(--shadow-md);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
    color: var(--color-primary);
  }

  .logo-inline {
    width: clamp(102px, 11vw, 120px);
    height: auto;
    max-height: 36px;
    object-fit: contain;
    display: block;
  }

  .logo-text {
    font-size: 1.125rem;
    font-family: var(--font-serif);
    letter-spacing: -0.01em;
    color: var(--color-primary);
    line-height: 1;
    transform: translateY(1px);
  }

  .logo-text strong {
    color: var(--color-accent);
    font-weight: 700;
  }

  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__nav ul {
    display: flex;
    list-style: none;
    gap: 0.125rem;
  }

  .header__nav a {
    display: block;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: color var(--transition);
  }

  .header__nav a:hover {
    color: var(--color-primary);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .icon-btn {
    background: none;
    border: none;
    padding: 0.5rem;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: color var(--transition);
    display: flex;
  }

  .icon-btn:hover {
    color: var(--color-primary);
  }

  .menu-btn {
    display: none;
    background: none;
    border: none;
    padding: 0.5rem;
    color: var(--color-primary);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 900px) {
    .header__nav {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-md);
      padding: 0.5rem 0 1rem;
    }

    .header__nav.open {
      display: block;
    }

    .header__nav ul {
      flex-direction: column;
      gap: 0;
    }

    .header__nav a {
      padding: 0.875rem 2rem;
      font-size: 1rem;
      border-radius: 0;
    }

    .menu-btn {
      display: flex;
    }

    .header__cta {
      display: none;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header")!;
  const menuBtn = document.getElementById("menu-toggle")!;
  const nav = document.getElementById("main-nav")!;

  window.addEventListener("scroll", () => {
    header.classList.toggle("scrolled", window.scrollY > 10);
  });

  menuBtn.addEventListener("click", () => {
    const isOpen = nav.classList.toggle("open");
    menuBtn.setAttribute("aria-expanded", String(isOpen));
  });
</script>
