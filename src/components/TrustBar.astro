---
const stats = [
  { value: '10,000+', label: 'Products in Stock' },
  { value: '15+',     label: 'Years Experience' },
  { value: '50+',     label: 'Brand Partners' },
  { value: '30-Day',  label: 'Return Policy' },
];
---

<section class="trust-bar" id="stats">
  <div class="container">
    <ul class="trust-bar__list">
      {stats.map((s) => (
        <li class="trust-bar__item">
          <span class="trust-bar__value">{s.value}</span>
          <span class="trust-bar__label">{s.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--color-primary);
    padding: 1.75rem 0;
  }

  .trust-bar__list {
    list-style: none;
    display: flex;
    justify-content: space-around;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .trust-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.25rem 1.5rem;
  }

  .trust-bar__item + .trust-bar__item {
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .trust-bar__value {
    font-family: var(--font-serif);
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .trust-bar__label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.25rem;
  }

  @media (max-width: 600px) {
    .trust-bar__item + .trust-bar__item {
      border-left: none;
    }

    .trust-bar__item {
      padding: 0.5rem 1rem;
    }
  }
</style>
