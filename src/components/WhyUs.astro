---
const features = [
  {
    title: 'Factory-Direct Pricing',
    desc: 'Cut out the middleman. We source directly from verified manufacturers to offer the most competitive prices on premium bathroom fixtures.',
    icon: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  },
  {
    title: 'Certified Quality',
    desc: 'Every product meets rigorous standards with certifications including CUPC, CE, and ISO compliance. Quality you can trust.',
    icon: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>',
  },
  {
    title: 'Fast & Reliable Shipping',
    desc: 'Nationwide delivery network ensures orders arrive safely and on time. Full tracking from warehouse to your door.',
    icon: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
  },
  {
    title: 'Wholesale Support',
    desc: 'Dedicated account managers for wholesalers and contractors. Tiered volume pricing and MOQ-friendly ordering.',
    icon: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
  {
    title: 'Expert Consultation',
    desc: 'Our product specialists help you find the perfect fixtures for any project — residential, commercial, or hospitality.',
    icon: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  },
  {
    title: '30-Day Returns',
    desc: "Shop with confidence. If you're not fully satisfied, we make returns simple and hassle-free with our guaranteed policy.",
    icon: '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4"/></svg>',
  },
];
---

<section class="why-us" id="about">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Our Promise</span>
      <h2 class="section-title">Why Choose xoxochina?</h2>
      <p class="section-desc">
        We're committed to delivering exceptional value and service — from individual homeowners to large-scale contractors.
      </p>
    </div>

    <div class="why-us__grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-card__icon" set:html={f.icon} />
          <h3 class="feature-card__title">{f.title}</h3>
          <p class="feature-card__desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-us {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .feature-card:hover {
    border-color: var(--color-accent-light);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .feature-card__icon {
    width: 52px;
    height: 52px;
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--color-accent-dark);
    transition: background var(--transition);
  }

  .feature-card:hover .feature-card__icon {
    background: var(--color-accent-light);
  }

  .feature-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.625rem;
  }

  .feature-card__desc {
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .why-us__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .why-us__grid { grid-template-columns: 1fr; }
  }
</style>
