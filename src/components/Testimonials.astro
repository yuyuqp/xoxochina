---
const testimonials = [
  {
    name: 'Marcus Johnson',
    role: 'General Contractor',
    company: 'Johnson Build Co.',
    avatar: 'https://placehold.co/80x80/dde0e8/4a5270?text=MJ',
    rating: 5,
    quote: "We've been purchasing from xoxochina for 3 years now. Their wholesale pricing is unbeatable, and the quality consistently impresses our clients. The dedicated account manager makes reordering effortless.",
  },
  {
    name: 'Sarah Chen',
    role: 'Interior Designer',
    company: 'Chen Design Studio',
    avatar: 'https://placehold.co/80x80/e8dcc8/7a6240?text=SC',
    rating: 5,
    quote: "The Brushed Gold faucet collection elevated every bathroom project I've completed this year. My clients love the quality, and xoxochina's variety means I always find the right piece for any style.",
  },
  {
    name: 'David Rivera',
    role: 'Homeowner',
    company: 'San Diego, CA',
    avatar: 'https://placehold.co/80x80/d8e8dc/3a6048?text=DR',
    rating: 5,
    quote: "Renovated two bathrooms completely with products from xoxochina. Outstanding value — the rainfall shower system I bought looks and works like a model twice the price. Shipping was fast too.",
  },
];
---

<section class="testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Customer Stories</span>
      <h2 class="section-title">What Our Clients Say</h2>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((t) => (
        <article class="testimonial-card">
          <div class="testimonial-card__stars" aria-label={`${t.rating} out of 5 stars`}>
            {[1,2,3,4,5].map(() => (
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <blockquote class="testimonial-card__quote">
            <svg class="quote-icon" width="36" height="36" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            {t.quote}
          </blockquote>
          <div class="testimonial-card__author">
            <img src={t.avatar} alt={t.name} width="80" height="80" loading="lazy" />
            <div>
              <p class="author-name">{t.name}</p>
              <p class="author-role">{t.role}</p>
              <p class="author-company">{t.company}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 5rem 0;
    background: var(--color-bg-soft);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: #ffffff;
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .testimonial-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .testimonial-card__stars {
    display: flex;
    gap: 2px;
    color: var(--color-accent);
  }

  .testimonial-card__quote {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    flex: 1;
    position: relative;
    padding-top: 0.5rem;
  }

  .quote-icon {
    color: var(--color-accent-light);
    position: absolute;
    top: -0.5rem;
    left: -0.25rem;
    opacity: 0.6;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial-card__author img {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-primary);
  }

  .author-role {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .author-company {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  @media (max-width: 900px) {
    .testimonials__grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .testimonials__grid { grid-template-columns: 1fr; }
  }
</style>
