---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "xoxochina – Premium Bathroom Fixtures",
    description = "Retail & wholesale bathroom fixtures. Faucets, sinks, shower heads, bathtubs and more. Factory-direct pricing for retailers and contractors.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link
            rel="icon"
            type="image/avif"
            href="/favicon.avif"
            sizes="120x120"
        />
        <link rel="icon" href="/favicon.ico" />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>
