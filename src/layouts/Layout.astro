---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "xoxochina – Premium Bathroom Fixtures",
    description = "Premium bathroom fixture collections for brand presentation, project sourcing, and wholesale partner inquiries.",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link
            rel="icon"
            type="image/avif"
            href={`${baseUrl}favicon.avif`}
            sizes="120x120"
        />
        <link rel="icon" href={`${baseUrl}favicon.ico`} />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>
